# Not to do list API
@baseUrl = http://localhost:8000/api/v1/tasks

### POST the task list
POST {{baseUrl}}
Content-Type: application/json

{
    
    "task":"sleeping",
    "hr":10,
    "type":"bad"

}

### GET the task list
GET {{baseUrl}}

### Update the task list
PATCH {{baseUrl}}
Content-Type: application/json


{
    "_id":"6a0f00a7068d5c9d4d9ec24f",
    "task":"coding",
    "hr": 3,
    "type": "bad"
}

### Delete the task list
DELETE {{baseUrl}}/6a0f07f3b943774b824c6cd4